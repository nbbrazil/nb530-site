{
    "version": 2,
    "builds": [
          { "src": "api/pagamento.js", "use": "@vercel/node" },
          { "src": "index.html", "use": "@vercel/static" }
    ],
    "routes": [
          { "src": "/api/pagamento", "dest": "/api/pagamento.js" },
          { "src": "/(.*)", "dest": "/index.html" }
    ]
}
